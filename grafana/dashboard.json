{
  "annotations": { "list": [] },
  "description": "ARRIS CM3500B CE cable modem DOCSIS 3.1 exporter dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Overview",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "Modem Status",
      "type": "stat",
      "gridPos": { "h": 3, "w": 3, "x": 0, "y": 1 },
      "targets": [
        { "expr": "cm3500_up", "refId": "A", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      }
    },
    {
      "title": "CM Status",
      "type": "stat",
      "gridPos": { "h": 3, "w": 3, "x": 3, "y": 1 },
      "targets": [
        { "expr": "cm3500_cm_status", "refId": "A", "instant": true, "format": "table" }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "filterable": false } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "status" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "basic" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } }
            ]
          }
        ]
      },
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "Value": true }, "renameByName": {} } }
      ]
    },
    {
      "title": "Uptime",
      "type": "stat",
      "gridPos": { "h": 3, "w": 3, "x": 6, "y": 1 },
      "targets": [
        { "expr": "cm3500_uptime_seconds", "refId": "A", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "orange", "value": 300 }, { "color": "green", "value": 3600 }] }
        }
      }
    },
    {
      "title": "DHCP Lease Remaining",
      "type": "gauge",
      "gridPos": { "h": 3, "w": 3, "x": 9, "y": 1 },
      "targets": [
        { "expr": "cm3500_dhcp_lease_remaining_seconds", "refId": "A", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "max": 600,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "orange", "value": 120 }, { "color": "green", "value": 300 }] }
        }
      }
    },
    {
      "title": "DHCP State",
      "type": "stat",
      "gridPos": { "h": 3, "w": 2, "x": 12, "y": 1 },
      "targets": [
        { "expr": "cm3500_dhcp_state", "refId": "A", "instant": true, "format": "table" }
      ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "Value": true } } }
      ]
    },
    {
      "title": "BPI State",
      "type": "stat",
      "gridPos": { "h": 3, "w": 2, "x": 14, "y": 1 },
      "targets": [
        { "expr": "cm3500_bpi_state", "refId": "A", "instant": true, "format": "table" }
      ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "Value": true } } }
      ]
    },
    {
      "title": "Dynamic CPE",
      "type": "stat",
      "gridPos": { "h": 3, "w": 2, "x": 16, "y": 1 },
      "targets": [
        { "expr": "cm3500_cpe_dynamic", "refId": "A", "instant": true }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" } } }
    },
    {
      "title": "Scrape Duration",
      "type": "stat",
      "gridPos": { "h": 3, "w": 2, "x": 18, "y": 1 },
      "targets": [
        { "expr": "cm3500_scrape_duration_seconds", "refId": "A", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 3 }, { "color": "red", "value": 5 }] }
        }
      }
    },
    {
      "title": "Ethernet PHY",
      "type": "stat",
      "gridPos": { "h": 3, "w": 2, "x": 20, "y": 1 },
      "targets": [
        { "expr": "cm3500_product_ethernet_phy_info", "refId": "A", "instant": true, "format": "table" }
      ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "Value": true, "job": true, "instance": true } } }
      ]
    },
    {
      "title": "Modem Info",
      "type": "table",
      "gridPos": { "h": 3, "w": 2, "x": 22, "y": 1 },
      "targets": [
        { "expr": "cm3500_info", "refId": "A", "instant": true, "format": "table" }
      ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "Value": true, "job": true, "instance": true }, "renameByName": {} } }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "align": "left", "filterable": false } },
        "overrides": []
      }
    },

    {
      "title": "Downstream SC-QAM",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 4 },
      "collapsed": false
    },
    {
      "title": "Downstream Power Level",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "targets": [
        {
          "expr": "cm3500_downstream_qam_power_dbmv",
          "refId": "A",
          "legendFormat": "Ch{{channel}} DCID{{dcid}} {{frequency_mhz}}MHz {{modulation}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "dBmV",
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 10, "pointSize": 5, "showPoints": "auto" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": -7 },
              { "color": "green", "value": -5 },
              { "color": "green", "value": 10 },
              { "color": "orange", "value": 12 }
            ]
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "min", "max"] }
      }
    },
    {
      "title": "Downstream SNR",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "targets": [
        {
          "expr": "cm3500_downstream_qam_snr_db",
          "refId": "A",
          "legendFormat": "Ch{{channel}} DCID{{dcid}} {{frequency_mhz}}MHz {{modulation}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "dB",
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 10, "pointSize": 5, "showPoints": "auto" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "orange", "value": 30 }, { "color": "green", "value": 33 }] }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "min"] }
      }
    },
    {
      "title": "Corrected Errors",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 13 },
      "targets": [
        { "expr": "increase(cm3500_downstream_qam_corrected_total[5m])", "refId": "A", "legendFormat": "Ch{{channel}} DCID{{dcid}}" }
      ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 50 } } },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "sum"] }
      }
    },
    {
      "title": "Uncorrectable Errors",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 13 },
      "targets": [
        { "expr": "increase(cm3500_downstream_qam_uncorrectable_total[5m])", "refId": "A", "legendFormat": "Ch{{channel}} DCID{{dcid}}" }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 50 }, "color": { "mode": "fixed", "fixedColor": "red" } }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "sum"] }
      }
    },
    {
      "title": "DS Power Tilt (Bar Chart)",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 13 },
      "targets": [
        { "expr": "cm3500_downstream_qam_power_dbmv", "refId": "A", "instant": true, "format": "table" }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "job": true, "instance": true },
            "renameByName": { "Value": "Power (dBmV)", "frequency_mhz": "Freq (MHz)" }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "dBmV",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": -7 }, { "color": "green", "value": 10 }, { "color": "red", "value": 12 }] }
        }
      },
      "options": { "xTickLabelRotation": 45, "groupWidth": 0.7, "barWidth": 0.9, "stacking": "none" }
    },

    {
      "title": "Downstream OFDM",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 },
      "collapsed": false
    },
    {
      "title": "OFDM RxMER",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 22 },
      "targets": [
        { "expr": "cm3500_downstream_ofdm_rxmer_db", "refId": "A", "legendFormat": "Ch{{channel}} {{measurement}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "dB",
          "custom": { "drawStyle": "line", "fillOpacity": 10 },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "orange", "value": 25 }, { "color": "green", "value": 31 }] }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] }
      }
    },
    {
      "title": "OFDM Channel Details",
      "type": "table",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 22 },
      "targets": [
        { "expr": "cm3500_downstream_ofdm_active_subcarriers", "refId": "A", "instant": true, "format": "table" },
        { "expr": "cm3500_downstream_ofdm_channel_width_mhz", "refId": "B", "instant": true, "format": "table" }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "job": true, "instance": true },
            "renameByName": { "Value #A": "Active Subcarriers", "Value #B": "Width (MHz)", "channel": "Channel", "fft_type": "FFT Type" }
          }
        }
      ],
      "fieldConfig": { "defaults": { "custom": { "align": "left" } } }
    },

    {
      "title": "Upstream",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 29 },
      "collapsed": false
    },
    {
      "title": "Upstream Power Level",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 30 },
      "targets": [
        { "expr": "cm3500_upstream_qam_power_dbmv", "refId": "A", "legendFormat": "Ch{{channel}} UCID{{ucid}} {{frequency_mhz}}MHz {{modulation}}" },
        { "expr": "cm3500_upstream_ofdma_tx_power_dbmv", "refId": "B", "legendFormat": "OFDMA Ch{{channel}} {{fft_type}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "dBmV",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "auto" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 49 }, { "color": "red", "value": 53 }] }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "min", "max"] }
      }
    },
    {
      "title": "Upstream Power Delta (Tilt)",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 4, "x": 12, "y": 30 },
      "targets": [
        { "expr": "max(cm3500_upstream_qam_power_dbmv) - min(cm3500_upstream_qam_power_dbmv)", "refId": "A", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "dBmV",
          "min": 0,
          "max": 15,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 3 }, { "color": "orange", "value": 6 }, { "color": "red", "value": 10 }] },
          "decimals": 1
        }
      },
      "description": "Max - Min upstream SC-QAM power across all channels. High tilt indicates frequency-dependent attenuation on the coax drop."
    },
    {
      "title": "Upstream Active Profile",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 30 },
      "targets": [
        { "expr": "cm3500_event_upstream_active_profile", "refId": "A", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      },
      "description": "Last seen upstream profile ID from event log. Profile downgrades (lower numbers) indicate upstream noise ingress on the CMTS segment."
    },
    {
      "title": "OFDMA Profile ID",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 30 },
      "targets": [
        { "expr": "cm3500_event_ofdma_profile_id", "refId": "A", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] }
        }
      },
      "description": "Last seen OFDM/OFDMA profile ID from CM-STATUS events. Tracks dynamic profile assignment by the CMTS."
    },
    {
      "title": "Upstream Symbol Rate",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 34 },
      "targets": [
        { "expr": "cm3500_upstream_qam_symbol_rate_ksym", "refId": "A", "legendFormat": "Ch{{channel}} UCID{{ucid}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "kSym/s", "custom": { "drawStyle": "line", "fillOpacity": 10 } }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] }
      }
    },

    {
      "title": "RF Spectrum",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 38 },
      "collapsed": true
    },
    {
      "title": "Spectrum Analyzer (Full Band)",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 39 },
      "targets": [
        { "expr": "cm3500_spectrum_bin_power_dbmv{chunk=\"0\"}", "refId": "A", "legendFormat": "{{frequency_mhz}} MHz" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "dBmV",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 15, "lineWidth": 1, "showPoints": "never" },
          "color": { "mode": "continuous-GrYlRd" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 0 }] }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "hidden" }
      },
      "description": "Per-bin spectrum power from the modem's active scan. Shows noise floor and potential ingress across 93–1218 MHz."
    },
    {
      "title": "Spectrum Chunk Power Summary",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 49 },
      "targets": [
        { "expr": "cm3500_spectrum_chunk_power_dbmv{stat=\"min\"}", "refId": "A", "legendFormat": "{{center_mhz}} MHz min" },
        { "expr": "cm3500_spectrum_chunk_power_dbmv{stat=\"avg\"}", "refId": "B", "legendFormat": "{{center_mhz}} MHz avg" },
        { "expr": "cm3500_spectrum_chunk_power_dbmv{stat=\"max\"}", "refId": "C", "legendFormat": "{{center_mhz}} MHz max" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "dBmV",
          "custom": { "drawStyle": "line", "fillOpacity": 5, "lineWidth": 1 }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] }
      },
      "description": "Min/avg/max power per 7.5 MHz chunk across the full downstream spectrum."
    },
    {
      "title": "Spectrum Chunks Overview",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 49 },
      "targets": [
        { "expr": "cm3500_spectrum_chunks", "refId": "A", "instant": true }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" }, "decimals": 0 }
      },
      "description": "Number of 7.5 MHz chunks returned by the last spectrum scan."
    },
    {
      "title": "Product Logging Components",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 49 },
      "targets": [
        { "expr": "cm3500_product_logging_components_enabled", "refId": "A", "instant": true, "format": "table" }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "job": true, "instance": true },
            "renameByName": { "Value": "Components", "group": "Group" }
          }
        }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "super-light-blue" } } },
      "options": { "xTickLabelRotation": 45, "groupWidth": 0.7, "barWidth": 0.9 },
      "description": "Enabled internal logging component counts by debug group from the product page."
    },

    {
      "title": "DHCP & Lease",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 58 },
      "collapsed": false
    },
    {
      "title": "DHCP Timers",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 59 },
      "targets": [
        { "expr": "cm3500_dhcp_lease_remaining_seconds", "refId": "A", "legendFormat": "Lease Remaining" },
        { "expr": "cm3500_dhcp_renew_remaining_seconds", "refId": "B", "legendFormat": "Renew Remaining" },
        { "expr": "cm3500_dhcp_rebind_remaining_seconds", "refId": "C", "legendFormat": "Rebind Remaining" },
        { "expr": "cm3500_dhcp_lease_total_seconds", "refId": "D", "legendFormat": "Lease Total" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] }
      }
    },
    {
      "title": "DHCP Renew No Response",
      "type": "stat",
      "gridPos": { "h": 7, "w": 4, "x": 12, "y": 59 },
      "targets": [
        { "expr": "cm3500_event_dhcp_renew_no_response", "refId": "A", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }] }
        }
      },
      "description": "Count of DHCP RENEW sent - No response events in the event log. Non-zero may indicate CMTS DHCP provisioning issues."
    },
    {
      "title": "QoS Shaper Capacity",
      "type": "gauge",
      "gridPos": { "h": 7, "w": 4, "x": 16, "y": 59 },
      "targets": [
        { "expr": "max(cm3500_qos_max_traffic_rate_kbps{direction=\"Downstream\"})", "refId": "A", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "kbps",
          "min": 0,
          "max": 1300000,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "decimals": 0
        }
      },
      "description": "Maximum downstream QoS traffic rate from the service flow config (shaper ceiling)."
    },
    {
      "title": "Service Flow Rates",
      "type": "table",
      "gridPos": { "h": 7, "w": 4, "x": 20, "y": 59 },
      "targets": [
        { "expr": "cm3500_qos_max_traffic_rate_kbps", "refId": "A", "instant": true, "format": "table" }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "job": true, "instance": true },
            "renameByName": { "Value": "Rate (kbps)", "direction": "Direction", "flow_index": "Flow" }
          }
        }
      ],
      "fieldConfig": { "defaults": { "custom": { "align": "left" } } }
    },

    {
      "title": "Event Log",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 66 },
      "collapsed": false
    },
    {
      "title": "Critical Event Counts",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 67 },
      "targets": [
        { "expr": "cm3500_event_t3_timeouts", "refId": "A", "instant": true },
