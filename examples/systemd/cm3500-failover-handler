#!/usr/bin/env bash
set -euo pipefail

state_file="${STATE_FILE:-/run/cm3500/link-state.json}"
failover_unit="${FAILOVER_TO_UNIT:-gateway-failover-to-backup.service}"
failback_unit="${FAILBACK_TO_UNIT:-gateway-failback-to-primary.service}"

if [[ ! -f "$state_file" ]]; then
  echo "state file missing: $state_file" >&2
  exit 0
fi

status="$(jq -r '.status // empty' "$state_file")"
reason="$(jq -r '.reason // empty' "$state_file")"

case "$status" in
  down)
    logger -t cm3500-failover-handler "CM3500 status=down reason=${reason:-unknown}; starting ${failover_unit}"
    exec systemctl start "$failover_unit"
    ;;
  up)
    logger -t cm3500-failover-handler "CM3500 status=up; starting ${failback_unit}"
    exec systemctl start "$failback_unit"
    ;;
  degraded)
    logger -t cm3500-failover-handler "CM3500 status=degraded; ignoring transitional state"
    exit 0
    ;;
  *)
    logger -t cm3500-failover-handler "CM3500 status unknown (${status:-empty}); ignoring"
    exit 0
    ;;
 esac
